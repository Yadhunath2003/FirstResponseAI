# Copy to .env and fill in. Never commit your real .env.
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash
MAX_TOKENS=1024

# Where the SQLite DB lives (relative to repo root).
DB_PATH=data/incident.db

# How many messages per channel to keep in the AI's context window.
MAX_CHANNEL_HISTORY=20
